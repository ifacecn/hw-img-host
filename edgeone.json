{
  "name": "hw-img-host",
  "buildCommand": "pnpm run build",
  "installCommand": "pnpm install",
  "outputDirectory": "./dist",
  "nodeVersion": "20.18.0",
  "rewrites": [
    {
      "source": "/login",
      "destination": "/index.html"
    },
    {
      "source": "/admin",
      "destination": "/index.html"
    },
    {
      "source": "/debug",
      "destination": "/index.html"
    },
    {
      "source": "/*",
      "destination": "/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/login",
      "destination": "/#/login",
      "statusCode": 302
    },
    {
      "source": "/admin",
      "destination": "/#/admin",
      "statusCode": 302
    }
  ],
  "headers": [
    {
      "source": "/*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    },
    {
      "source": "/assets/*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/favicon.ico",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800"
        }
      ]
    }
  ],
  "caches": [
    {
      "source": "/assets/*",
      "cacheTtl": 86400
    },
    {
      "source": "/*",
      "cacheTtl": 0
    }
  ],
  "cloudFunctions": {
    "nodejs": {
      "externalNodeModules": [
        "express",
        "multer"
      ],
      "includeFiles": [
        "node-functions/**"
      ]
    }
  },
  "nodeFunctionsConfig": {
    "maxDuration": 60
  }
}